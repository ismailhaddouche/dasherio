# ============================================
# DisherIo Environment Configuration
# Copy this file to .env and update the values
# ============================================

# ============================================
# Application Settings
# ============================================
NODE_ENV=production
PORT=80
HTTPS_PORT=443

# ============================================
# Security (REQUIRED - CHANGE THESE!)
# ============================================
# Generate a strong secret: openssl rand -base64 64
JWT_SECRET=change-this-to-a-secure-random-string-min-32-characters
JWT_EXPIRES=8h

# ============================================
# Database (REQUIRED - CHANGE THESE!)
# ============================================
MONGO_ROOT_USER=admin
MONGO_ROOT_PASS=change-this-to-a-secure-password

# Connection string (auto-generated from above)
# MONGODB_URI=mongodb://admin:password@mongo:27017/disherio?authSource=admin

# ============================================
# Frontend Configuration
# ============================================
FRONTEND_URL=http://localhost

# ============================================
# Logging
# ============================================
# Options: debug, info, warn, error
LOG_LEVEL=info

# ============================================
# Optional: Email Configuration (for notifications)
# ============================================
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@disherio.com

# ============================================
# Optional: Cloud Storage (for uploads)
# ============================================
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# ============================================
# Optional: Monitoring
# ============================================
# SENTRY_DSN=
# LOGGLY_TOKEN=

# ============================================
# Development Only (do not use in production)
# ============================================
# DEBUG=true
# MOCK_DATA=false
